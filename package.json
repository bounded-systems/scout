{
  "name": "@bounded-systems/scout",
  "version": "0.1.1",
  "description": "Content-addressed surface reads (file/grep/files) with anchored-chain provenance",
  "bounded": {
    "tagline": "Content-addressed surface reads (file/grep/files) with anchored-chain provenance",
    "kind": "door"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/scout.git"
  },
  "homepage": "https://github.com/bounded-systems/scout#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/scout/issues"
  },
  "keywords": [
    "scout",
    "content-addressed",
    "provenance",
    "grep",
    "surface-reads"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bounded-systems/anchored-chain": "workspace:*",
    "@bounded-systems/anchored-chain-sqlite": "workspace:*",
    "@bounded-systems/cas": "workspace:*"
  }
}
